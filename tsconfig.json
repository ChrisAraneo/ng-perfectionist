{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "alwaysStrict": true,
    "declaration": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "lib": ["es2020", "dom"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "paths": {},
    "removeComments": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "sourceRoot": "/",
    "strictNullChecks": true,
    "target": "es2020"
  },
  "exclude": ["node_modules", "dist"],
  "include": ["*.ts", "src/**/*.ts"]
}
