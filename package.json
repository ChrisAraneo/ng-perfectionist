{
  "name": "@chris.araneo/eslint-plugin-ng-perfectionist",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/ChrisAraneo/ng-perfectionist",
  "bugs": {
    "url": "https://github.com/ChrisAraneo/ng-perfectionist/issues"
  },
  "license": "MIT",
  "author": "Krzysztof Pająk (Chris Araneo) <chris.araneo@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc --build tsconfig.json",
    "chores": "npm run lint:fix && npm run format",
    "format": "npx sort-package-json && prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.56.0"
  },
  "devDependencies": {
    "@chris.araneo/eslint-config": "^0.0.128",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sort-package-json": "^3.6.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
